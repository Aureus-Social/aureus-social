# Aureus Social Pro — variables d'environnement
# Copiez ce fichier en .env.local (en local) ou configurez dans Vercel (en production).
# Ne commitez jamais .env.local ni vos vraies clés.

# Supabase (obligatoire pour l'app)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optionnel — API / production
# SUPABASE_SERVICE_KEY=
# ALLOWED_ORIGIN=https://app.aureussocial.be
# RESEND_API_KEY=
# ANTHROPIC_API_KEY=
